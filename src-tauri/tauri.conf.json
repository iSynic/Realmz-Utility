{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Realmz Scenario Utility",
  "version": "0.1.1",
  "identifier": "local.realmz.scenario-utility",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../src/": "src/",
      "../public/": "public/",
      "../assets/realmz/resources/icons/": "assets/realmz/resources/icons/",
      "../assets/realmz/resources/pictures/": "assets/realmz/resources/pictures/",
      "../package.json": "package.json"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
